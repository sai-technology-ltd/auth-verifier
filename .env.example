PORT=3001
SUPABASE_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
# Optional. If omitted, derived as ${SUPABASE_ISSUER}/.well-known/jwks.json
SUPABASE_JWKS_URL=
# Optional. If set, token aud must match.
SUPABASE_AUDIENCE=authenticated
FORWARDED_USER_ID_HEADER=x-user-id
FORWARDED_ROLE_HEADER=x-user-role
FORWARDED_PERMISSIONS_HEADER=x-user-permissions
